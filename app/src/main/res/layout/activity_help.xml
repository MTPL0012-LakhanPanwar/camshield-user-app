<?xml version="1.0" encoding="utf-8"?>
<!--
    Help & Guide screen.

    Design notes:
    - Uses the same visual system as the rest of the app:
        * Root background: bg_radiating_glow
        * Section container: bg_card_dark (#141B2D, 16dp corners)
        * Primary text:   #FFFFFF
        * Secondary text: #8A92A6
        * Accent:         @color/btn_blue (#135BEC)
        * Success dot:    #00C853   Danger dot: #FF4D4D
    - No business logic is affected. HelpActivity only touches the toolbar.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_radiating_glow"
    tools:context=".activity.HelpActivity">

    <include
        android:id="@+id/iToolbar"
        layout="@layout/layout_toolbar_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <!-- ===================== App Overview ===================== -->
            <LinearLayout style="@style/HelpCard">

                <LinearLayout style="@style/HelpStepRow">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_help_icon_tile"
                        android:padding="8dp"
                        android:src="@drawable/icon_camblock"
                        android:contentDescription="App icon" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="CamBlock App"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="4dp"
                    android:text="This app manages camera access for secure facility entry and exit. Your device camera is automatically locked when entering and unlocked when exiting secure areas."
                    android:textColor="#8A92A6"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ===================== How to Use ===================== -->
            <LinearLayout style="@style/HelpCard">

                <LinearLayout style="@style/HelpStepRow">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_help_icon_tile"
                        android:padding="8dp"
                        android:src="@drawable/ic_help_two"
                        android:contentDescription="How to Use" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="How to Use"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Step 1 : Entry / Lock -->
                <LinearLayout
                    style="@style/HelpStepRow"
                    android:layout_marginTop="16dp">

                    <TextView
                        style="@style/HelpStepBadge"
                        android:text="1" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/HelpItemTitle"
                            android:text="Entry — Lock Camera" />

                        <TextView
                            style="@style/HelpItemSubtitle"
                            android:text="Scan the Entry QR code at the facility entrance." />
                    </LinearLayout>
                </LinearLayout>

                <!-- Step 2 : Exit / Unlock -->
                <LinearLayout
                    style="@style/HelpStepRow"
                    android:layout_marginTop="14dp">

                    <TextView
                        style="@style/HelpStepBadge"
                        android:text="2" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/HelpItemTitle"
                            android:text="Exit — Unlock Camera" />

                        <TextView
                            style="@style/HelpItemSubtitle"
                            android:text="Scan the Exit QR code when leaving the facility." />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===================== Status Indicators ===================== -->
            <LinearLayout style="@style/HelpCard">

                <LinearLayout style="@style/HelpStepRow">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_help_icon_tile"
                        android:padding="8dp"
                        android:src="@drawable/ic_shield_gray"
                        android:contentDescription="Status Indicators"
                        app:tint="#8A92A6" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Status Indicators"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Locked -->
                <LinearLayout
                    style="@style/HelpStepRow"
                    android:layout_marginTop="16dp">

                    <ImageView
                        style="@style/HelpStatusDot"
                        android:contentDescription="Locked"
                        app:tint="#FF4D4D" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/HelpItemTitle"
                            android:text="Locked"
                            android:textColor="#FF4D4D" />

                        <TextView
                            style="@style/HelpItemSubtitle"
                            android:text="Camera access is disabled." />
                    </LinearLayout>
                </LinearLayout>

                <!-- Unlocked -->
                <LinearLayout
                    style="@style/HelpStepRow"
                    android:layout_marginTop="14dp">

                    <ImageView
                        style="@style/HelpStatusDot"
                        android:contentDescription="Unlocked"
                        app:tint="#00C853" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/HelpItemTitle"
                            android:text="Unlocked"
                            android:textColor="#00C853" />

                        <TextView
                            style="@style/HelpItemSubtitle"
                            android:text="Camera access is enabled." />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===================== Required Permissions ===================== -->
            <LinearLayout style="@style/HelpCard">

                <LinearLayout style="@style/HelpStepRow">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_help_icon_tile"
                        android:padding="10dp"
                        android:src="@drawable/ic_device_admin_red"
                        android:contentDescription="Required Permissions"
                        app:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Required Permissions"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Device Admin -->
                <LinearLayout
                    style="@style/HelpStepRow"
                    android:layout_marginTop="16dp">

                    <ImageView
                        style="@style/HelpPermIcon"
                        android:src="@drawable/ic_top_permission"
                        android:contentDescription="Device Administrator" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/HelpItemTitle"
                            android:text="Device Administrator" />

                        <TextView
                            style="@style/HelpItemSubtitle"
                            android:text="Required to lock and unlock the camera hardware." />
                    </LinearLayout>
                </LinearLayout>

                <!-- Camera -->
                <LinearLayout
                    style="@style/HelpStepRow"
                    android:layout_marginTop="14dp">

                    <!-- Glyph-only icon: wrap in the matching circular tile so it
                         visually aligns with the compound icons used above / below. -->
                    <ImageView
                        style="@style/HelpPermIcon"
                        android:background="@drawable/bg_help_perm_tile"
                        android:padding="7dp"
                        android:src="@drawable/ic_camera_on"
                        android:contentDescription="Camera"
                        app:tint="@color/btn_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/HelpItemTitle"
                            android:text="Camera" />

                        <TextView
                            style="@style/HelpItemSubtitle"
                            android:text="Required for QR code scanning." />
                    </LinearLayout>
                </LinearLayout>

                <!-- Internet -->
                <LinearLayout
                    style="@style/HelpStepRow"
                    android:layout_marginTop="14dp">

                    <ImageView
                        style="@style/HelpPermIcon"
                        android:src="@drawable/ic_permi_restore"
                        android:contentDescription="Internet" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/HelpItemTitle"
                            android:text="Internet" />

                        <TextView
                            style="@style/HelpItemSubtitle"
                            android:text="Required for secure backend communication." />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===================== Troubleshooting ===================== -->
            <LinearLayout style="@style/HelpCard">

                <LinearLayout style="@style/HelpStepRow">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_help_icon_tile"
                        android:padding="8dp"
                        android:src="@drawable/ic_permi_restore"
                        android:contentDescription="Troubleshooting"
                        app:tint="#8A92A6" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Troubleshooting"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    style="@style/HelpBullet"
                    android:layout_marginTop="14dp"
                    android:text="•  QR code not scanning? Ensure proper lighting and focus." />

                <TextView
                    style="@style/HelpBullet"
                    android:text="•  Camera not locking? Check Device Admin permission." />

                <TextView
                    style="@style/HelpBullet"
                    android:text="•  App not responding? Restart the application." />

                <TextView
                    style="@style/HelpBullet"
                    android:text="•  Backend connection issues? Check your network connectivity." />
            </LinearLayout>

            <!-- ===================== Need Help? ===================== -->
            <LinearLayout style="@style/HelpCard">

                <LinearLayout style="@style/HelpStepRow">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_help_icon_tile"
                        android:padding="8dp"
                        android:src="@drawable/ic_help_two"
                        android:contentDescription="Need help" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="Need Help?"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Contact your facility administrator for assistance with:"
                    android:textColor="#8A92A6"
                    android:textSize="14sp" />

                <TextView
                    style="@style/HelpBullet"
                    android:layout_marginTop="10dp"
                    android:text="•  QR code access" />

                <TextView
                    style="@style/HelpBullet"
                    android:text="•  Permission issues" />

                <TextView
                    style="@style/HelpBullet"
                    android:text="•  Account problems" />
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
