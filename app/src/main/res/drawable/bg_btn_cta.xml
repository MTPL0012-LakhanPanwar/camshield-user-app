<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable rounded CTA background for plain AppCompat Buttons
    (used where MaterialButton is not available, e.g. Theme.AppCompat screens).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#0F49C4" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_disabled" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/btn_blue" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</selector>
