        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="@android:color/transparent"
        android:pathData="
            M4,64 L4,20 Q4,4 20,4 L64,4
            M216,4 L260,4 Q276,4 276,20 L276,64
            M276,216 L276,260 Q276,276 260,276 L216,276
